+    def _enum_pairs_rec(self, st, side, remaining, used_cats, limit_cat, prefix,
+                        used_chip_ids):
+        """遞迴枚舉長度 N 的合法行動組合（N=actions_per_turn）。
+
+        limit_cat=True：同類別（含 pass 例外，pass 不佔類別）至多出現一次，
+          與原 2 格實作同語意——用 used_cats 逐層累積並排除。
+        limit_cat=False：不排除任何類別重複（A1『同類限制關』格）；為避免
+          純 pass 組合與『非 pass 開頭』重複列舉，仍維持『pass 只能排在非 pass
+          之後』的既有去重慣例（見下方 dedupe 判斷），語意上等同原碼「避免重複
+          列 (pass,X) 與 (X,pass)」的推廣版：一個組合中，一旦出現 pass，其後
+          全部只能是 pass（禁止 pass 之後再出現非 pass 行動）。
+
+        used_chip_ids：本回合組合中已選過的晶片 id（不論類別限制開關與否恆
+        追蹤）——A1『同類限制關』新增的旋鈕只解除『類別』上限（移動/晶片/
+        領航員三大類可同回合重複出現），不代表同一張牌可以無中生有用兩次；
+        手牌是有限資源、legal_actions 枚舉時尚未真的移除該牌（施行才移除），
+        若不擋，limit_cat=False 時會枚舉出『同一張晶片用兩次』的非法組合，
+        實際施行到第二次會因手牌已無該牌而 crash（remove 找不到元素）。此為
+        重構後新發現的邊界情況，於此補上、不影響 limit_cat=True 原行為（原
+        行為下『晶片』類別本身已至多一次，天然不會撞到同張牌兩次的情況）。
+        """
+        if remaining == 0:
+            return [prefix]
+        acts = self.legal_actions(
+            st, side, used_categories=(used_cats if limit_cat else frozenset()))
+        out = []
+        prefix_has_pass = len(prefix) > 0 and prefix[-1].category() == 'pass'
+        for a in acts:
+            if prefix_has_pass and a.category() != 'pass':
+                continue   # pass 之後不得再出現非 pass（避免重複列舉排列）
+            if a.kind == '晶片' and a.chip_id in used_chip_ids:
+                continue   # 同一張牌本回合已用過，不可再用第二次（資源不可穿越）
+            cat = a.category()
+            next_used = used_cats if cat == 'pass' else (used_cats | {cat})
+            next_chips = (used_chip_ids | {a.chip_id}) if a.kind == '晶片' \
+                else used_chip_ids
+            out.extend(self._enum_pairs_rec(
+                st, side, remaining - 1, next_used, limit_cat, prefix + (a,),
+                next_chips))
+        return out
 
